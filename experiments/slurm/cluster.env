# Cluster-specific settings for the M1 SLURM launch scripts.
# Resolved 2026-07-08 against the VICOMTECH Abacus cluster (abacus-login-01),
# account di13.
#
# Sourced by submit_all.sh (to build `sbatch` CLI flags — SLURM directives
# inside a #SBATCH line are static text, not shell-evaluated, so
# account/partition/gres must be passed as sbatch arguments) and by each
# *.sbatch script's body (for paths used at runtime).

export SLURM_ACCOUNT="di13"               # sbatch --account
export SLURM_QOS="qos_di13"               # sbatch --qos
export PART_CPU="vicomtech"               # partition for datagen + precompute (01, 02)
export PART_GPU="vicomtech"               # partition for training (03, 04)
export GRES_GPU="gpu:a40:1"               # sbatch --gres; A40 (48GB, 8 GPUs/2 nodes) chosen over H100 (scarcest,
                                           # only 6 total) and T4 (16GB, slower) for R010 + R011 phase B

export REPO_ROOT="/gpfs/VICOMTECH/proiektuak/DI13/SYSTEMICO/HierarchicalFM/gridfm-graphkit"
export VENV_ACTIVATE="/gpfs/VICOMTECH/proiektuak/DI13/SYSTEMICO/HierarchicalFM/env/.venv/bin/activate"
export MLRUNS_ROOT="$REPO_ROOT/mlruns"
export SLURM_LOG_ROOT="$MLRUNS_ROOT/slurm-logs"
export GRIDFM_RESULTS_ROOT="$MLRUNS_ROOT/result-summaries"

# datakit's Julia backend (PythonCall/PowerModels.jl) needs a persistent,
# SHARED depot — NOT node-local /tmp. Local dev hit "PythonCall.jl did not
# start properly" after /tmp got cleaned; on a multi-node array, node-local
# /tmp also means every task recompiles Julia packages from scratch. Point
# this at shared, persistent storage.
export JULIA_DEPOT_PATH="/gpfs/VICOMTECH/proiektuak/DI13/SYSTEMICO/HierarchicalFM/julia_depot"

export MLFLOW_ALLOW_FILE_STORE=true       # matches CI (.github/workflows/ci-build.yaml)
