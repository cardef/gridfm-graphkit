# Cluster-specific settings for the M1 SLURM launch scripts.
# Nothing in this repo or its history names an actual SLURM cluster (the only
# documented cluster is LSF, see README.md's bsub section) — every value below
# is a placeholder. Fill in before running submit_all.sh.
#
# Sourced by submit_all.sh (to build `sbatch` CLI flags — SLURM directives
# inside a #SBATCH line are static text, not shell-evaluated, so
# account/partition/gres must be passed as sbatch arguments) and by each
# *.sbatch script's body (for paths used at runtime).

export SLURM_ACCOUNT="CHANGE_ME"          # sbatch --account
export PART_CPU="CHANGE_ME"               # partition for datagen + precompute (01, 02)
export PART_GPU="CHANGE_ME"               # partition for training (03, 04)
export GRES_GPU="gpu:1"                   # sbatch --gres; add a type if the cluster needs one, e.g. gpu:a100:1

export REPO_ROOT="CHANGE_ME"              # absolute path to this gridfm-graphkit checkout on the cluster
export VENV_ACTIVATE="CHANGE_ME"          # e.g. /path/to/.venv/bin/activate — must already have
                                           # `pip install -e ".[dev,test]"` + gridfm-datakit editable
                                           # sibling installed (see repo CLAUDE.md); these scripts don't
                                           # install anything, only activate

# datakit's Julia backend (PythonCall/PowerModels.jl) needs a persistent,
# SHARED depot — NOT node-local /tmp. Local dev hit "PythonCall.jl did not
# start properly" after /tmp got cleaned; on a multi-node array, node-local
# /tmp also means every task recompiles Julia packages from scratch. Point
# this at shared, persistent storage.
export JULIA_DEPOT_PATH="CHANGE_ME"

export MLFLOW_ALLOW_FILE_STORE=true       # matches CI (.github/workflows/ci-build.yaml)
