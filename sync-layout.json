{
  "version": 1,
  "repo_local_folders": {
    "gridfm-mlruns": "mlruns",
    "gridfm-papers": "papers"
  },
  "ownership": {
    "git_roots": [
      "experiments",
      "idea-stage",
      "refine-logs",
      "research-wiki"
    ],
    "syncthing_roots": [
      "mlruns",
      "papers"
    ]
  },
  "gpfs_bridge": {
    "type": "explicit_rsync",
    "gpfs_repo_env": "GRIDFM_GPFS_REPO",
    "syncthing_repo_env": "GRIDFM_SYNCTHING_REPO",
    "allow_delete": false,
    "verification": "rsync_checksum_dry_run",
    "single_writer": true,
    "routes": {
      "workstation_to_gpfs": [
        "papers"
      ],
      "gpfs_to_workstation": [
        "mlruns"
      ]
    }
  }
}
